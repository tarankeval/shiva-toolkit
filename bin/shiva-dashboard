#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

json=false
watch=false
interval="${SHIVA_DASHBOARD_INTERVAL:-5}"
count=0
health_tmp="$(mktemp "${TMPDIR:-/tmp}/shiva-dashboard.XXXXXX")" || exit 1
trap 'rm -f "$health_tmp"' EXIT

usage() {
  cat <<'EOF'
Usage: shiva dashboard [--json] [--watch] [--interval seconds] [--count cycles]

Show a compact operational dashboard from the shared Shiva Health Engine.
EOF
}

while (($#)); do
  case "$1" in
    --json) json=true ;;
    --watch) watch=true ;;
    --interval)
      shift
      if [[ -z "${1:-}" ]]; then
        printf 'Missing seconds after --interval.\n' >&2
        exit 1
      fi
      interval="$1"
      ;;
    --interval=*)
      interval="${1#--interval=}"
      ;;
    --count)
      shift
      if [[ -z "${1:-}" ]]; then
        printf 'Missing cycles after --count.\n' >&2
        exit 1
      fi
      count="$1"
      ;;
    --count=*)
      count="${1#--count=}"
      ;;
    -h|--help|help) usage; exit 0 ;;
    *) printf 'Unknown dashboard option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

if [[ ! "$interval" =~ ^[0-9]+$ ]]; then
  printf 'Dashboard interval must be a number.\n' >&2
  exit 1
fi
if [[ ! "$count" =~ ^[0-9]+$ ]]; then
  printf 'Dashboard count must be a number.\n' >&2
  exit 1
fi
if [[ "$json" == true && "$watch" == true ]]; then
  printf 'Dashboard --json cannot be combined with --watch.\n' >&2
  exit 1
fi

json_escape() {
  shiva_health_engine_json_escape "$1"
}

node_count() {
  local count=0 entry
  for entry in $SHIVA_NODES; do
    [[ -n "$entry" ]] && ((count+=1))
  done
  printf '%s' "$count"
}

watchdog_state() {
  [[ -r "$SHIVA_WATCHDOG_STATE_FILE" ]] || { printf 'NO DATA'; return 0; }
  cat "$SHIVA_WATCHDOG_STATE_FILE"
}

collect_dashboard_state() {
  shiva_health_engine_collect >"$health_tmp"
  passed="$(awk -F '\t' '$1 == "ok" {count += 1} END {print count + 0}' "$health_tmp")"
  warnings="$(awk -F '\t' '$1 == "warn" {count += 1} END {print count + 0}' "$health_tmp")"
  failures="$(awk -F '\t' '$1 == "fail" {count += 1} END {print count + 0}' "$health_tmp")"
  total=$((passed + warnings + failures))
  if (( total > 0 )); then
    health_percent=$(((passed * 100 + warnings * 50) / total))
  else
    health_percent=0
  fi
  if (( failures > 0 )); then
    overall="attention_required"
  elif (( warnings > 0 )); then
    overall="good_with_warnings"
  else
    overall="excellent"
  fi
  nodes="$(node_count)"
  watchdog="$(watchdog_state)"
}

render_dashboard_json() {
  printf '{'
  shiva_json_metadata "health-engine" "$overall" "$health_percent"
  printf '"passed":%s,' "$passed"
  printf '"warnings":%s,' "$warnings"
  printf '"failures":%s,' "$failures"
  printf '"nodes":%s,' "$nodes"
  printf '"watchdog":"%s",' "$(json_escape "$watchdog")"
  if shiva_enabled "$SHIVA_TELEGRAM_ENABLED"; then
    printf '"telegram":"enabled",'
  else
    printf '"telegram":"disabled",'
  fi
  printf '"checks":['
  awk -F '\t' '
    function esc(value) {
      gsub(/\\/,"\\\\",value)
      gsub(/"/,"\\\"",value)
      gsub(/\t/,"\\t",value)
      return value
    }
    {
      if (count > 0) printf ","
      printf "{\"level\":\"%s\",\"key\":\"%s\",\"label\":\"%s\",\"value\":\"%s\"}", esc($1), esc($2), esc($3), esc($4)
      count += 1
    }
  ' "$health_tmp"
  printf ']}\n'
}

render_dashboard_text() {
  shiva_title "SHIVA DASHBOARD v$SHIVA_VERSION"

  if [[ "$watch" == true ]]; then
    shiva_status ok "Refresh" "${interval}s"
  fi

  case "$overall" in
    excellent) shiva_status ok "Health" "${health_percent}%" ;;
    good_with_warnings) shiva_status warn "Health" "${health_percent}%" ;;
    *) shiva_status fail "Health" "${health_percent}%" ;;
  esac

  shiva_status ok "Passed" "$passed"
  if (( warnings > 0 )); then
    shiva_status warn "Warnings" "$warnings"
  else
    shiva_status ok "Warnings" "$warnings"
  fi
  if (( failures > 0 )); then
    shiva_status fail "Failures" "$failures"
  else
    shiva_status ok "Failures" "$failures"
  fi
  shiva_status ok "Nodes" "$nodes"

  case "$watchdog" in
    ok) shiva_status ok "Watchdog" "OK" ;;
    fail:*) shiva_status fail "Watchdog" "$watchdog" ;;
    "NO DATA") shiva_status warn "Watchdog" "NO DATA" ;;
    *) shiva_status warn "Watchdog" "$watchdog" ;;
  esac

  if shiva_enabled "$SHIVA_TELEGRAM_ENABLED"; then
    shiva_status ok "Telegram" "ENABLED"
  else
    shiva_status warn "Telegram" "DISABLED"
  fi

  printf '\nAttention:\n'
  awk -F '\t' '
    $1 != "ok" {
      printf "  %-5s %-18s %s\n", $1, $3, $4
      shown += 1
    }
    END {exit shown == 0}
  ' "$health_tmp" || printf '  none\n'
}

if [[ "$json" == true ]]; then
  collect_dashboard_state
  render_dashboard_json
  exit 0
fi

cycles=0
while true; do
  if [[ "$watch" == true ]]; then
    clear 2>/dev/null || true
  fi
  collect_dashboard_state
  render_dashboard_text
  ((cycles+=1))
  if [[ "$watch" != true ]] || { (( count > 0 )) && (( cycles >= count )); }; then
    break
  fi
  sleep "$interval"
done
