#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

json=false
health_tmp="$(mktemp "${TMPDIR:-/tmp}/shiva-health.XXXXXX")" || exit 1
trap 'rm -f "$health_tmp"' EXIT

usage() {
  cat <<'EOF'
Usage: shiva health [--json]

Show full server health summary from the shared Shiva Health Engine.
EOF
}

while (($#)); do
  case "$1" in
    --json) json=true ;;
    -h|--help|help) usage; exit 0 ;;
    *) printf 'Unknown health option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

shiva_health_engine_collect >"$health_tmp"

passed="$(awk -F '\t' '$1 == "ok" {count += 1} END {print count + 0}' "$health_tmp")"
warnings="$(awk -F '\t' '$1 == "warn" {count += 1} END {print count + 0}' "$health_tmp")"
failures="$(awk -F '\t' '$1 == "fail" {count += 1} END {print count + 0}' "$health_tmp")"
total=$((passed + warnings + failures))
if (( total > 0 )); then
  health_percent=$(((passed * 100 + warnings * 50) / total))
else
  health_percent=0
fi

if (( failures > 0 )); then
  overall="attention_required"
  exit_code=2
elif (( warnings > 0 )); then
  overall="good_with_warnings"
  exit_code=1
else
  overall="excellent"
  exit_code=0
fi

if [[ "$json" == true ]]; then
  printf '{'
  printf '"schema":%s,' "$SHIVA_JSON_SCHEMA"
  printf '"version":"%s",' "$(shiva_health_engine_json_escape "$SHIVA_VERSION")"
  printf '"hostname":"%s",' "$(shiva_health_engine_json_escape "$SHIVA_HOSTNAME")"
  printf '"profile":"%s",' "$(shiva_health_engine_json_escape "$SHIVA_PROFILE_NAME")"
  printf '"overall":"%s",' "$overall"
  printf '"health_percent":%s,' "$health_percent"
  printf '"passed":%s,' "$passed"
  printf '"warnings":%s,' "$warnings"
  printf '"failures":%s,' "$failures"
  printf '"checks":['
  awk -F '\t' '
    function esc(value) {
      gsub(/\\/,"\\\\",value)
      gsub(/"/,"\\\"",value)
      gsub(/\t/,"\\t",value)
      return value
    }
    {
      if (count > 0) printf ","
      printf "{\"level\":\"%s\",\"key\":\"%s\",\"label\":\"%s\",\"value\":\"%s\"}", esc($1), esc($2), esc($3), esc($4)
      count += 1
    }
  ' "$health_tmp"
  printf ']}\n'
  exit "$exit_code"
fi

shiva_title "SHIVA HEALTH v$SHIVA_VERSION"
while IFS=$'\t' read -r level _key label value; do
  shiva_status "$level" "$label" "$value"
done <"$health_tmp"

printf '\n══════════════════════════════════════\n\n%sHealth Summary%s\n\n' "$SHIVA_BOLD" "$SHIVA_RESET"
shiva_status ok "Passed" "$passed"
shiva_status warn "Warning" "$warnings"
shiva_status fail "Errors" "$failures"
printf '\n%sServer Health%s\n\n%d%%\n' "$SHIVA_BOLD" "$SHIVA_RESET" "$health_percent"
printf '\n══════════════════════════════════════\n\n%sOverall Status%s\n\n' "$SHIVA_BOLD" "$SHIVA_RESET"
case "$overall" in
  attention_required) shiva_status fail "" "ATTENTION REQUIRED" ;;
  good_with_warnings) shiva_status warn "" "GOOD, WITH WARNINGS" ;;
  *) shiva_status ok "" "EXCELLENT" ;;
esac
exit "$exit_code"
