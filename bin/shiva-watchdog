#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

once=false
status_only=false

usage() {
  cat <<'EOF'
Usage: shiva watchdog [--once] [--status]

Run Shiva Toolkit watchdog checks. Use --once for a single check cycle.
Use --status to show the last recorded watchdog state without running checks.
EOF
}

while (($#)); do
  case "$1" in
    --once) once=true ;;
    --status) status_only=true ;;
    -h|--help|help) usage; exit 0 ;;
    *) printf 'Unknown watchdog option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

show_status() {
  shiva_title "SHIVA WATCHDOG STATUS v$SHIVA_VERSION"
  if [[ ! -r "$SHIVA_WATCHDOG_STATE_FILE" ]]; then
    shiva_status warn "State" "NO DATA"
    printf '\nState file: %s\n' "$SHIVA_WATCHDOG_STATE_FILE"
    return 1
  fi

  local state count targets
  state="$(<"$SHIVA_WATCHDOG_STATE_FILE")"
  case "$state" in
    ok) shiva_status ok "State" "OK"; return 0 ;;
    fail:*)
      count="${state#fail:}"
      targets=""
      if [[ "$count" == *:* ]]; then
        targets="${count#*:}"
        count="${count%%:*}"
      fi
      shiva_status fail "State" "$count failure(s)"
      [[ -n "$targets" ]] && shiva_status warn "Repair targets" "$targets"
      return 2
      ;;
    *) shiva_status warn "State" "$state"; return 1 ;;
  esac
}

if [[ "$status_only" == true ]]; then
  show_status
  exit $?
fi

add_repair_target() {
  local target="$1" existing
  for existing in "${repair_targets[@]:-}"; do
    [[ "$existing" == "$target" ]] && return 0
  done
  repair_targets+=("$target")
}

repair_target_allowed() {
  local target="$1" allowed
  for allowed in $SHIVA_WATCHDOG_REPAIR_TARGETS; do
    [[ "$allowed" == "$target" ]] && return 0
  done
  return 1
}

repair_target_string() {
  local target separator=""
  for target in "${repair_targets[@]:-}"; do
    printf '%s%s' "$separator" "$target"
    separator=","
  done
}

run_auto_repairs() {
  local target
  for target in "${repair_targets[@]:-}"; do
    if repair_target_allowed "$target"; then
      "$SCRIPT_DIR/shiva-repair" --apply "$target" || true
    else
      shiva_history_add watchdog info "auto-repair skipped for $target: not allowed"
    fi
  done
}

watchdog_cycle() {
  local failures=0 state root_percent raw_temp interface previous_state current_state targets
  local -a repair_targets=()

  shiva_gateway_ok &&
    shiva_status ok "Gateway" "OK" ||
    { shiva_status fail "Gateway" "FAILED"; ((failures+=1)); add_repair_target network; }

  shiva_connectivity_ok &&
    shiva_status ok "Internet" "OK" ||
    { shiva_status fail "Internet" "FAILED"; ((failures+=1)); add_repair_target network; }

  shiva_dns_ok &&
    shiva_status ok "DNS" "OK" ||
    { shiva_status fail "DNS" "FAILED"; ((failures+=1)); add_repair_target dns; }

  if shiva_check_enabled CHECK_INTERFACES; then
    if [[ -n "$REQUIRED_INTERFACES" ]]; then
      for interface in $REQUIRED_INTERFACES; do
        shiva_required_interface_healthy "$interface" &&
          shiva_status ok "Interface $interface" "UP" ||
          { shiva_status fail "Interface $interface" "DOWN OR MISSING"; ((failures+=1)); add_repair_target network; }
      done
    fi
  fi

  if shiva_check_enabled CHECK_OPENVPN; then
    state="$(shiva_openvpn_state)"
    if [[ "$(shiva_service_level "$state")" == "ok" ]]; then
      shiva_status ok "OPENVPN" "$state"
    else
      shiva_status fail "OPENVPN" "$state"
      ((failures+=1))
      add_repair_target openvpn
    fi
  fi

  read -r root_percent < <(df -P / | awk 'NR==2 {gsub("%","",$5); print $5}')
  if (( root_percent >= 95 )); then
    shiva_status fail "Root FS" "${root_percent}%"
    ((failures+=1))
  elif (( root_percent >= 85 )); then
    shiva_status warn "Root FS" "${root_percent}%"
  else
    shiva_status ok "Root FS" "${root_percent}%"
  fi

  if shiva_check_enabled CHECK_TEMPERATURE && [[ -r /sys/class/thermal/thermal_zone0/temp ]]; then
    raw_temp="$(< /sys/class/thermal/thermal_zone0/temp)"
    if (( raw_temp >= 80000 )); then
      shiva_status fail "CPU" "$((raw_temp / 1000))C"
      ((failures+=1))
    elif (( raw_temp >= 70000 )); then
      shiva_status warn "CPU" "$((raw_temp / 1000))C"
    else
      shiva_status ok "CPU" "$((raw_temp / 1000))C"
    fi
  fi

  previous_state=""
  [[ -r "$SHIVA_WATCHDOG_STATE_FILE" ]] &&
    previous_state="$(<"$SHIVA_WATCHDOG_STATE_FILE")"

  if (( failures > 0 )); then
    targets="$(repair_target_string)"
    current_state="fail:$failures"
    [[ -n "$targets" ]] && current_state+=":$targets"
    if [[ "$previous_state" != "$current_state" ]]; then
      if [[ -n "$targets" ]]; then
        shiva_history_add watchdog fail "$failures failure(s) detected; repair targets: $targets"
      else
        shiva_history_add watchdog fail "$failures failure(s) detected"
      fi
    fi
    mkdir -p "$(dirname -- "$SHIVA_WATCHDOG_STATE_FILE")" 2>/dev/null || true
    printf '%s\n' "$current_state" >"$SHIVA_WATCHDOG_STATE_FILE" 2>/dev/null || true
    if [[ "$previous_state" != "$current_state" ]] && shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR"; then
      run_auto_repairs
    fi
    return 2
  fi

  current_state="ok"
  if [[ "$previous_state" != "$current_state" ]]; then
    shiva_history_add watchdog ok "all checks passed"
  fi
  mkdir -p "$(dirname -- "$SHIVA_WATCHDOG_STATE_FILE")" 2>/dev/null || true
  printf '%s\n' "$current_state" >"$SHIVA_WATCHDOG_STATE_FILE" 2>/dev/null || true
  return 0
}

while true; do
  shiva_title "SHIVA WATCHDOG v$SHIVA_VERSION"
  watchdog_cycle
  rc=$?
  [[ "$once" == true ]] && exit "$rc"
  sleep "$SHIVA_WATCHDOG_INTERVAL"
done
