#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

mode=""
status_only=false
config_only=false

usage() {
  cat <<'EOF'
Usage: shiva watchdog [--once|--watch] [--status] [--config]

Run Shiva Toolkit watchdog checks.
Use --once for a single check cycle.
Use --watch for continuous service mode.
Use --status to show the last recorded watchdog state without running checks.
Use --config to show watchdog automation settings.
EOF
}

while (($#)); do
  case "$1" in
    --once) mode="once" ;;
    --watch) mode="watch" ;;
    --status) status_only=true ;;
    --config) config_only=true ;;
    -h|--help|help) usage; exit 0 ;;
    *) printf 'Unknown watchdog option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

show_status() {
  local meta_value rc=0
  shiva_title "SHIVA WATCHDOG STATUS v$SHIVA_VERSION"
  if [[ ! -r "$SHIVA_WATCHDOG_STATE_FILE" ]]; then
    shiva_status warn "State" "NO DATA"
    printf '\nState file: %s\n' "$SHIVA_WATCHDOG_STATE_FILE"
    return 1
  fi

  local state count targets
  state="$(<"$SHIVA_WATCHDOG_STATE_FILE")"
  case "$state" in
    ok) shiva_status ok "State" "OK"; rc=0 ;;
    fail:*)
      count="${state#fail:}"
      targets=""
      if [[ "$count" == *:* ]]; then
        targets="${count#*:}"
        count="${count%%:*}"
      fi
      shiva_status fail "State" "$count failure(s)"
      [[ -n "$targets" ]] && shiva_status warn "Repair targets" "$targets"
      rc=2
      ;;
    *) shiva_status warn "State" "$state"; rc=1 ;;
  esac
  if [[ -r "$SHIVA_WATCHDOG_META_FILE" ]]; then
    meta_value="$(sed -n 's/.*"last_success":"\([^"]*\)".*/\1/p' "$SHIVA_WATCHDOG_META_FILE")"
    [[ -n "$meta_value" ]] && shiva_status ok "Last success" "$meta_value"
    meta_value="$(sed -n 's/.*"consecutive_failures":\([0-9][0-9]*\).*/\1/p' "$SHIVA_WATCHDOG_META_FILE")"
    [[ -n "$meta_value" ]] && shiva_status ok "Consecutive failures" "$meta_value"
  fi
  return "$rc"
}

show_config() {
  shiva_title "SHIVA WATCHDOG CONFIG v$SHIVA_VERSION"
  shiva_status ok "Interval" "${SHIVA_WATCHDOG_INTERVAL}s"
  if shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR"; then
    shiva_status warn "Auto repair" "ENABLED"
  else
    shiva_status ok "Auto repair" "DISABLED"
  fi
  shiva_status ok "Repair targets" "$SHIVA_WATCHDOG_REPAIR_TARGETS"
  shiva_status ok "Failure threshold" "$SHIVA_WATCHDOG_FAILURE_THRESHOLD"
  if shiva_enabled "$SHIVA_NOTIFY_ON_WATCHDOG"; then
    shiva_status ok "Notifications" "ENABLED"
  else
    shiva_status warn "Notifications" "DISABLED"
  fi
  shiva_status ok "State file" "$SHIVA_WATCHDOG_STATE_FILE"
  shiva_status ok "Metadata file" "$SHIVA_WATCHDOG_META_FILE"
  shiva_status ok "History file" "$SHIVA_HISTORY_FILE"
}

if [[ "$status_only" == true ]]; then
  show_status
  exit $?
fi

if [[ "$config_only" == true ]]; then
  show_config
  exit 0
fi

if [[ -z "$mode" ]]; then
  printf 'Choose an explicit watchdog mode: --once or --watch.\n' >&2
  usage >&2
  exit 1
fi

add_repair_target() {
  local target="$1" existing
  for existing in "${repair_targets[@]:-}"; do
    [[ "$existing" == "$target" ]] && return 0
  done
  repair_targets+=("$target")
}

repair_target_allowed() {
  local target="$1" allowed
  for allowed in $SHIVA_WATCHDOG_REPAIR_TARGETS; do
    [[ "$allowed" == "$target" ]] && return 0
  done
  return 1
}

repair_target_string() {
  local target separator=""
  for target in "${repair_targets[@]:-}"; do
    printf '%s%s' "$separator" "$target"
    separator=","
  done
}

run_auto_repairs() {
  local target
  for target in "${repair_targets[@]:-}"; do
    if repair_target_allowed "$target"; then
      "$SCRIPT_DIR/shiva-repair" --apply --verify-after "$target" || true
    else
      shiva_history_add watchdog info "auto-repair skipped for $target: not allowed"
    fi
  done
}

notify_watchdog() {
  local level="$1" message="$2"
  shiva_enabled "$SHIVA_NOTIFY_ON_WATCHDOG" || return 0
  "$SCRIPT_DIR/shiva-notify" --category "watchdog-$level" "[$level] $SHIVA_HOSTNAME: $message" || true
}

write_watchdog_state() {
  local state="$1" dir
  dir="$(dirname -- "$SHIVA_WATCHDOG_STATE_FILE")"
  mkdir -p "$dir" 2>/dev/null || return 0
  { printf '%s\n' "$state" >"$SHIVA_WATCHDOG_STATE_FILE"; } 2>/dev/null || return 0
}

watchdog_meta_value() {
  local key="$1"
  [[ -r "$SHIVA_WATCHDOG_META_FILE" ]] || return 1
  sed -n "s/.*\"$key\":\\([^,}]*\\).*/\\1/p" "$SHIVA_WATCHDOG_META_FILE" |
    sed 's/^"//;s/"$//'
}

write_watchdog_meta() {
  local state="$1" failures="$2" targets="$3" consecutive="$4" last_success="$5" dir tmp_file
  dir="$(dirname -- "$SHIVA_WATCHDOG_META_FILE")"
  mkdir -p "$dir" 2>/dev/null || return 0
  tmp_file="$dir/.watchdog.$$"
  {
    printf '{'
    shiva_json_metadata "watchdog" "$state" "null"
    printf '"state":"%s",' "$(shiva_json_escape "$state")"
    printf '"failures":%s,' "$failures"
    printf '"consecutive_failures":%s,' "$consecutive"
    printf '"failure_threshold":%s,' "$SHIVA_WATCHDOG_FAILURE_THRESHOLD"
    printf '"last_success":"%s",' "$(shiva_json_escape "$last_success")"
    printf '"targets":"%s",' "$(shiva_json_escape "$targets")"
    printf '"updated_at":"%s"' "$(date -Iseconds)"
    printf '}\n'
  } >"$tmp_file" 2>/dev/null &&
    mv "$tmp_file" "$SHIVA_WATCHDOG_META_FILE" 2>/dev/null || {
      rm -f "$tmp_file" 2>/dev/null || true
      return 0
    }
}

watchdog_cycle() {
  local failures=0 state root_percent raw_temp interface previous_state current_state targets
  local previous_consecutive consecutive_failures last_success alert_ready=false
  local -a repair_targets=()

  shiva_gateway_ok &&
    shiva_status ok "Gateway" "OK" ||
    { shiva_status fail "Gateway" "FAILED"; ((failures+=1)); add_repair_target network; }

  shiva_connectivity_ok &&
    shiva_status ok "Internet" "OK" ||
    { shiva_status fail "Internet" "FAILED"; ((failures+=1)); add_repair_target network; }

  shiva_dns_ok &&
    shiva_status ok "DNS" "OK" ||
    { shiva_status fail "DNS" "FAILED"; ((failures+=1)); add_repair_target dns; }

  if shiva_check_enabled CHECK_INTERFACES; then
    if [[ -n "$REQUIRED_INTERFACES" ]]; then
      for interface in $REQUIRED_INTERFACES; do
        shiva_required_interface_healthy "$interface" &&
          shiva_status ok "Interface $interface" "UP" ||
          { shiva_status fail "Interface $interface" "DOWN OR MISSING"; ((failures+=1)); add_repair_target network; }
      done
    fi
  fi

  if shiva_check_enabled CHECK_OPENVPN; then
    state="$(shiva_openvpn_state)"
    if [[ "$(shiva_service_level "$state")" == "ok" ]]; then
      shiva_status ok "OPENVPN" "$state"
    else
      shiva_status fail "OPENVPN" "$state"
      ((failures+=1))
      add_repair_target openvpn
    fi
  fi

  read -r root_percent < <(df -P / | awk 'NR==2 {gsub("%","",$5); print $5}')
  if (( root_percent >= 95 )); then
    shiva_status fail "Root FS" "${root_percent}%"
    ((failures+=1))
  elif (( root_percent >= 85 )); then
    shiva_status warn "Root FS" "${root_percent}%"
  else
    shiva_status ok "Root FS" "${root_percent}%"
  fi

  if shiva_check_enabled CHECK_TEMPERATURE && [[ -r /sys/class/thermal/thermal_zone0/temp ]]; then
    raw_temp="$(< /sys/class/thermal/thermal_zone0/temp)"
    if (( raw_temp <= 0 )); then
      shiva_status warn "CPU" "UNKNOWN"
    elif (( raw_temp >= 80000 )); then
      shiva_status fail "CPU" "$((raw_temp / 1000))C"
      ((failures+=1))
    elif (( raw_temp >= 70000 )); then
      shiva_status warn "CPU" "$((raw_temp / 1000))C"
    else
      shiva_status ok "CPU" "$((raw_temp / 1000))C"
    fi
  fi

  previous_state=""
  [[ -r "$SHIVA_WATCHDOG_STATE_FILE" ]] &&
    previous_state="$(<"$SHIVA_WATCHDOG_STATE_FILE")"
  previous_consecutive="$(watchdog_meta_value consecutive_failures || true)"
  [[ "$previous_consecutive" =~ ^[0-9]+$ ]] || previous_consecutive=0
  last_success="$(watchdog_meta_value last_success || true)"

  if (( failures > 0 )); then
    consecutive_failures=$((previous_consecutive + 1))
    targets="$(repair_target_string)"
    current_state="fail:$failures"
    [[ -n "$targets" ]] && current_state+=":$targets"
    if [[ "$SHIVA_WATCHDOG_FAILURE_THRESHOLD" =~ ^[0-9]+$ ]] &&
      (( consecutive_failures >= SHIVA_WATCHDOG_FAILURE_THRESHOLD )); then
      alert_ready=true
    fi
    if [[ "$previous_state" != "$current_state" ]] && [[ "$alert_ready" == true ]]; then
      if [[ -n "$targets" ]]; then
        shiva_history_add watchdog fail "$failures failure(s) detected; repair targets: $targets"
        notify_watchdog fail "$failures failure(s) detected; repair targets: $targets"
      else
        shiva_history_add watchdog fail "$failures failure(s) detected"
        notify_watchdog fail "$failures failure(s) detected"
      fi
    fi
    write_watchdog_state "$current_state"
    write_watchdog_meta "fail" "$failures" "$targets" "$consecutive_failures" "$last_success"
    if [[ "$previous_state" != "$current_state" ]] && [[ "$alert_ready" == true ]] && shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR"; then
      run_auto_repairs
    fi
    return 2
  fi

  current_state="ok"
  last_success="$(date -Iseconds)"
  if [[ "$previous_state" != "$current_state" ]]; then
    shiva_history_add watchdog ok "all checks passed"
    notify_watchdog ok "all checks passed"
  fi
  write_watchdog_state "$current_state"
  write_watchdog_meta "ok" 0 "" 0 "$last_success"
  return 0
}

if [[ "$mode" == "watch" ]]; then
  printf 'Press Ctrl+C to stop.\n'
fi

while true; do
  shiva_title "SHIVA WATCHDOG v$SHIVA_VERSION"
  watchdog_cycle
  rc=$?
  [[ "$mode" == "once" ]] && exit "$rc"
  sleep "$SHIVA_WATCHDOG_INTERVAL"
done
