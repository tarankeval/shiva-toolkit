#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

show_state_diagnostics() {
  local issues=0 path dir tmp_file seen_paths="" json=false first=true status
  if [[ "${1:-}" == "--json" ]]; then
    json=true
  fi

  if [[ "$json" == true ]]; then
    printf '{"paths":['
  else
    shiva_title "SHIVA DOCTOR STATE"
  fi

  for path in "$SHIVA_STATE_DIR" "$(dirname -- "$SHIVA_HISTORY_FILE")" \
    "$(dirname -- "$SHIVA_WATCHDOG_STATE_FILE")" "$SHIVA_NOTIFY_STATE_DIR"; do
    case " $seen_paths " in
      *" $path "*) continue ;;
    esac
    seen_paths+=" $path"
    if [[ -d "$path" ]]; then
      status="directory"
    elif mkdir -p "$path" 2>/dev/null; then
      status="created"
    else
      status="missing"
      ((issues+=1))
    fi
    if [[ "$json" == true ]]; then
      [[ "$first" == true ]] || printf ','
      first=false
      printf '{"path":"%s","status":"%s"}' "$path" "$status"
    else
      case "$status" in
        directory) shiva_status ok "$path" "DIRECTORY" ;;
        created) shiva_status ok "$path" "CREATED" ;;
        *) shiva_status warn "$path" "MISSING" ;;
      esac
    fi
  done

  if [[ "$json" == true ]]; then
    printf '],"files":['
    first=true
  fi

  for path in "$SHIVA_HISTORY_FILE" "$SHIVA_WATCHDOG_STATE_FILE"; do
    dir="$(dirname -- "$path")"
    tmp_file="$dir/.shiva-write-test.$$"
    if mkdir -p "$dir" 2>/dev/null && { printf 'test\n' >"$tmp_file"; } 2>/dev/null; then
      rm -f "$tmp_file"
      status="writable"
    else
      status="not_writable"
      ((issues+=1))
    fi
    if [[ "$json" == true ]]; then
      [[ "$first" == true ]] || printf ','
      first=false
      printf '{"path":"%s","status":"%s"}' "$path" "$status"
    else
      case "$status" in
        writable) shiva_status ok "$path" "WRITABLE" ;;
        *) shiva_status warn "$path" "NOT WRITABLE" ;;
      esac
    fi
  done

  if [[ "$json" == true ]]; then
    printf '],"issues":%s}\n' "$issues"
    (( issues == 0 ))
    return
  fi

  if (( issues > 0 )); then
    printf '\nRun sudo ./install.sh or configure SHIVA_HISTORY_FILE and SHIVA_WATCHDOG_STATE_FILE to writable paths.\n'
    return 1
  fi
  return 0
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

show_config_diagnostics() {
  local json=false issues=0 nodes_count=0 entry openvpn_enabled docker_enabled
  if [[ "${1:-}" == "--json" ]]; then
    json=true
  fi

  for entry in $SHIVA_NODES; do
    [[ -n "$entry" ]] && ((nodes_count+=1))
  done

  shiva_check_enabled CHECK_OPENVPN || openvpn_enabled=false
  shiva_check_enabled CHECK_OPENVPN && openvpn_enabled=true
  shiva_check_enabled CHECK_DOCKER || docker_enabled=false
  shiva_check_enabled CHECK_DOCKER && docker_enabled=true

  if shiva_enabled "$SHIVA_TELEGRAM_ENABLED" &&
    [[ -z "$SHIVA_TELEGRAM_BOT_TOKEN" || -z "$SHIVA_TELEGRAM_CHAT_ID" ]]; then
    ((issues+=1))
  fi
  if shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR" && [[ -z "$SHIVA_WATCHDOG_REPAIR_TARGETS" ]]; then
    ((issues+=1))
  fi
  if [[ "$nodes_count" -eq 0 ]]; then
    ((issues+=1))
  fi

  if [[ "$json" == true ]]; then
    printf '{'
    printf '"hostname":"%s",' "$(json_escape "$SHIVA_HOSTNAME")"
    printf '"profile":"%s",' "$(json_escape "$SHIVA_PROFILE_NAME")"
    printf '"profile_source":"%s",' "$(json_escape "$SHIVA_PROFILE_SOURCE")"
    printf '"check_openvpn":%s,' "$openvpn_enabled"
    printf '"check_docker":%s,' "$docker_enabled"
    printf '"watchdog_interval":%s,' "$SHIVA_WATCHDOG_INTERVAL"
    printf '"watchdog_auto_repair":%s,' "$(shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR" && printf true || printf false)"
    printf '"watchdog_repair_targets":"%s",' "$(json_escape "$SHIVA_WATCHDOG_REPAIR_TARGETS")"
    printf '"telegram_enabled":%s,' "$(shiva_enabled "$SHIVA_TELEGRAM_ENABLED" && printf true || printf false)"
    printf '"nodes":%s,' "$nodes_count"
    printf '"issues":%s' "$issues"
    printf '}\n'
    (( issues == 0 ))
    return
  fi

  shiva_title "SHIVA DOCTOR CONFIG"
  shiva_status ok "Hostname" "$SHIVA_HOSTNAME"
  shiva_status ok "Profile" "$SHIVA_PROFILE_NAME"
  shiva_status ok "Profile source" "$SHIVA_PROFILE_SOURCE"
  shiva_status ok "OpenVPN check" "$openvpn_enabled"
  shiva_status ok "Docker check" "$docker_enabled"
  shiva_status ok "Watchdog interval" "${SHIVA_WATCHDOG_INTERVAL}s"
  if shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR"; then
    shiva_status warn "Auto repair" "ENABLED"
  else
    shiva_status ok "Auto repair" "DISABLED"
  fi
  shiva_status ok "Repair targets" "${SHIVA_WATCHDOG_REPAIR_TARGETS:-none}"
  if shiva_enabled "$SHIVA_TELEGRAM_ENABLED"; then
    if [[ -n "$SHIVA_TELEGRAM_BOT_TOKEN" && -n "$SHIVA_TELEGRAM_CHAT_ID" ]]; then
      shiva_status ok "Telegram" "ENABLED"
    else
      shiva_status fail "Telegram" "ENABLED BUT INCOMPLETE"
    fi
  else
    shiva_status warn "Telegram" "DISABLED"
  fi
  if (( nodes_count > 0 )); then
    shiva_status ok "Nodes" "$nodes_count"
  else
    shiva_status warn "Nodes" "NONE"
  fi

  (( issues == 0 ))
}

show_release_diagnostics() {
  local json=false issues=0 checks=0 first=true project_dir status detail name
  local -a json_entries=()
  project_dir="$(cd -- "$SCRIPT_DIR/.." && pwd)"
  if [[ "${1:-}" == "--json" ]]; then
    json=true
  fi

  record_release_check() {
    local check_name="$1" check_status="$2" check_detail="$3" entry
    ((checks+=1))
    if [[ "$check_status" != "ok" ]]; then
      ((issues+=1))
    fi
    if [[ "$json" == true ]]; then
      entry='{"name":"'"$(json_escape "$check_name")"'","status":"'"$check_status"'","detail":"'"$(json_escape "$check_detail")"'"}'
      json_entries+=("$entry")
    else
      case "$check_status" in
        ok) shiva_status ok "$check_name" "$check_detail" ;;
        warn) shiva_status warn "$check_name" "$check_detail" ;;
        *) shiva_status fail "$check_name" "$check_detail" ;;
      esac
    fi
  }

  check_release_file() {
    local check_name="$1" file_path="$2"
    if [[ -r "$project_dir/$file_path" ]]; then
      record_release_check "$check_name" ok "$file_path"
    else
      record_release_check "$check_name" fail "missing $file_path"
    fi
  }

  check_release_exec() {
    local command_path="$1"
    if [[ -x "$project_dir/$command_path" ]]; then
      record_release_check "$command_path" ok "executable"
    else
      record_release_check "$command_path" fail "missing or not executable"
    fi
  }

  check_release_text() {
    local check_name="$1" file_path="$2" pattern="$3" ok_detail="$4"
    if [[ -r "$project_dir/$file_path" ]] && grep -q -- "$pattern" "$project_dir/$file_path"; then
      record_release_check "$check_name" ok "$ok_detail"
    else
      record_release_check "$check_name" fail "not found in $file_path"
    fi
  }

  if [[ "$json" != true ]]; then
    shiva_title "SHIVA DOCTOR RELEASE"
  fi

  check_release_file "README" "README.md"
  check_release_file "Roadmap" "ROADMAP.md"
  check_release_file "Debian control" "debian/control"
  check_release_file "Build script" "packaging/build-deb.sh"
  check_release_file "Installer" "install.sh"
  check_release_file "Systemd unit" "packaging/systemd/shiva-watchdog.service"
  check_release_file "Smoke tests" "tests/smoke.sh"
  check_release_file "Automation tests" "tests/automation.sh"

  for name in shiva shiva-watchdog shiva-repair shiva-history shiva-log shiva-notify \
    shiva-advisor shiva-dashboard shiva-service shiva-nodes shiva-cluster; do
    check_release_exec "bin/$name"
  done

  check_release_text "Package version" "packaging/build-deb.sh" "1.1.0~dev-1" "1.1.0~dev-1"
  check_release_text "Systemd ExecStart" "packaging/systemd/shiva-watchdog.service" "ExecStart=@BINDIR@/shiva-watchdog" "watchdog service"
  check_release_text "Notify state dir" "install.sh" "/var/lib/shiva/notify" "created by installer"
  check_release_text "README release doctor" "README.md" "shiva doctor release" "documented"

  if [[ "$json" == true ]]; then
    printf '{"checks":%s,"issues":%s,"status":"%s","items":[' "$checks" "$issues" "$([[ "$issues" -eq 0 ]] && printf ok || printf fail)"
    for detail in "${json_entries[@]}"; do
      [[ "$first" == true ]] || printf ','
      first=false
      printf '%s' "$detail"
    done
    printf ']}\n'
    (( issues == 0 ))
    return
  fi

  printf '\n'
  if (( issues == 0 )); then
    shiva_status ok "Release readiness" "$checks checks passed"
  else
    shiva_status fail "Release readiness" "$issues issue(s)"
  fi
  (( issues == 0 ))
}

case "${1:-}" in
  state) shift; show_state_diagnostics "${1:-}"; exit $? ;;
  config) shift; show_config_diagnostics "${1:-}"; exit $? ;;
  release) shift; show_release_diagnostics "${1:-}"; exit $? ;;
  -h|--help|help)
    cat <<'EOF'
Usage: shiva doctor [state|config|release]

Diagnose toolkit dependencies, host setup, state paths, configuration, and release readiness.
EOF
    exit 0
    ;;
esac

shiva_title "SHIVA DOCTOR"
shiva_status ok "Release" "$(shiva_version_string) $SHIVA_RELEASE"
shiva_status ok "Hostname" "$SHIVA_HOSTNAME"
shiva_status ok "Profile" "$SHIVA_PROFILE_NAME"
issues=0
for command in ip df free getent systemctl; do
  if shiva_have "$command"; then
    shiva_status ok "$command" "AVAILABLE"
  else
    shiva_status fail "$command" "MISSING"
    ((issues+=1))
  fi
done

if (( EUID == 0 )); then
  shiva_status ok "Privileges" "ROOT"
else
  shiva_status warn "Privileges" "LIMITED (use sudo for full diagnostics)"
fi

if shiva_check_enabled CHECK_SMART; then
  smart_disk="$SMART_DISK"
  [[ -n "$smart_disk" ]] || smart_disk="$(shiva_root_disk || true)"
  if [[ -n "$smart_disk" ]]; then
    shiva_smart_health "$smart_disk"
    if [[ "$SHIVA_SMART_STATE" == "unknown" ]]; then
      shiva_status warn "SMART detail" "${SHIVA_SMART_ERROR//$'\n'/ | }"
    fi
  fi
fi

printf '\n'
if (( issues == 0 )); then
  shiva_status ok "Toolkit" "READY"
else
  shiva_status fail "Toolkit" "$issues REQUIRED COMMAND(S) MISSING"
  exit 2
fi
