#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

limit="${1:-50}"
case "$limit" in
  -h|--help|help)
    cat <<'EOF'
Usage: shiva history [lines]

Show recent Shiva Toolkit operational history.
EOF
    exit 0
    ;;
esac

if [[ ! "$limit" =~ ^[0-9]+$ ]]; then
  printf 'History line count must be a number.\n' >&2
  exit 1
fi

shiva_title "SHIVA HISTORY v$SHIVA_VERSION"

if [[ ! -r "$SHIVA_HISTORY_FILE" ]]; then
  printf 'No history recorded yet.\n'
  printf '\nHistory file: %s\n' "$SHIVA_HISTORY_FILE"
  exit 0
fi

tail -n "$limit" "$SHIVA_HISTORY_FILE" |
  awk -F '\t' '
    {
      split($1, parts, "T")
      day = parts[1]
      if (day != last_day) {
        if (last_day != "") print ""
        print day
        last_day = day
      }
      printf "  %-5s %-12s %s\n", $2, $3, $4
    }
  '
