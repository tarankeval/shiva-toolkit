#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

limit=50
module_filter=""
level_filter=""
date_filter=""
service_filter=""
summary=false
json=false
history_tmp="$(mktemp "${TMPDIR:-/tmp}/shiva-history.XXXXXX")" || exit 1
trap 'rm -f "$history_tmp"' EXIT

usage() {
  cat <<'EOF'
Usage: shiva history [--summary] [--json] [--date YYYY-MM-DD] [--module name] [--service name] [--level level] [lines]

Show recent Shiva Toolkit operational history.
EOF
}

normalize_level() {
  case "${1,,}" in
    info) printf 'info' ;;
    warning|warn) printf 'warn' ;;
    error|err|fail|critical) printf 'fail' ;;
    ok) printf 'ok' ;;
    *) printf '%s' "$1" ;;
  esac
}

while (($#)); do
  case "$1" in
  -h|--help|help)
    usage
    exit 0
    ;;
  --summary)
    summary=true
    ;;
  --json)
    json=true
    ;;
  --date)
    shift
    if [[ -z "${1:-}" ]]; then
      printf 'Missing date after --date.\n' >&2
      exit 1
    fi
    date_filter="$1"
    ;;
  --date=*)
    date_filter="${1#--date=}"
    ;;
  --module)
    shift
    if [[ -z "${1:-}" ]]; then
      printf 'Missing module name after --module.\n' >&2
      exit 1
    fi
    module_filter="$1"
    ;;
  --module=*)
    module_filter="${1#--module=}"
    ;;
  --level)
    shift
    if [[ -z "${1:-}" ]]; then
      printf 'Missing level after --level.\n' >&2
      exit 1
    fi
    level_filter="$(normalize_level "$1")"
    ;;
  --level=*)
    level_filter="$(normalize_level "${1#--level=}")"
    ;;
  --service)
    shift
    if [[ -z "${1:-}" ]]; then
      printf 'Missing service after --service.\n' >&2
      exit 1
    fi
    service_filter="$1"
    ;;
  --service=*)
    service_filter="${1#--service=}"
    ;;
  *)
    limit="$1"
    ;;
  esac
  shift
done

if [[ ! "$limit" =~ ^[0-9]+$ ]]; then
  printf 'History line count must be a number.\n' >&2
  exit 1
fi

if [[ "$json" != true ]]; then
  shiva_title "SHIVA HISTORY v$SHIVA_VERSION"
fi

if [[ ! -r "$SHIVA_HISTORY_FILE" ]]; then
  if [[ "$json" == true ]]; then
    printf '{'
    shiva_json_metadata "history" "ok" "null"
    printf '"checks":[],"entries":[],"history_file":"%s"}\n' "$(shiva_json_escape "$SHIVA_HISTORY_FILE")"
  else
    printf 'No history recorded yet.\n'
    printf '\nHistory file: %s\n' "$SHIVA_HISTORY_FILE"
  fi
  exit 0
fi

awk -F '\t' -v module_filter="$module_filter" -v level_filter="$level_filter" \
  -v date_filter="$date_filter" -v service_filter="$service_filter" '
    function lower(value) { return tolower(value) }
    (module_filter == "" || $3 == module_filter) &&
    (level_filter == "" || $2 == level_filter) &&
    (date_filter == "" || index($1, date_filter) == 1) &&
    (service_filter == "" || index(lower($3 " " $4), lower(service_filter)) > 0) { print }
  ' "$SHIVA_HISTORY_FILE" |
  tail -n "$limit" >"$history_tmp"

if [[ "$json" == true ]]; then
  printf '{'
  shiva_json_metadata "history" "ok" "null"
  printf '"checks":[],"entries":['
  awk -F '\t' '
    function esc(value) {
      gsub(/\\/,"\\\\",value)
      gsub(/"/,"\\\"",value)
      gsub(/\t/,"\\t",value)
      return value
    }
    {
      if (count > 0) printf ","
      printf "{\"time\":\"%s\",\"level\":\"%s\",\"module\":\"%s\",\"message\":\"%s\"}", esc($1), esc($2), esc($3), esc($4)
      count += 1
    }
  ' "$history_tmp"
  printf ']}\n'
  exit 0
fi

if [[ "$summary" == true ]]; then
  awk -F '\t' '
    {
      level[$2] += 1
      module[$3] += 1
      total += 1
    }
    END {
      printf "Total: %d\n\n", total
      print "By level"
      for (name in level) printf "  %-12s %d\n", name, level[name]
      print ""
      print "By module"
      for (name in module) printf "  %-12s %d\n", name, module[name]
    }
  ' "$history_tmp"
  exit 0
fi

awk -F '\t' '
    {
      split($1, parts, "T")
      day = parts[1]
      if (day != last_day) {
        if (last_day != "") print ""
        print day
        last_day = day
      }
      printf "  %-5s %-12s %s\n", $2, $3, $4
    }
  ' "$history_tmp"
