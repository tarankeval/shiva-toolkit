#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

limit=50
module_filter=""

usage() {
  cat <<'EOF'
Usage: shiva history [--module name] [lines]

Show recent Shiva Toolkit operational history.
EOF
}

while (($#)); do
  case "$1" in
  -h|--help|help)
    usage
    exit 0
    ;;
  --module)
    shift
    if [[ -z "${1:-}" ]]; then
      printf 'Missing module name after --module.\n' >&2
      exit 1
    fi
    module_filter="$1"
    ;;
  --module=*)
    module_filter="${1#--module=}"
    ;;
  *)
    limit="$1"
    ;;
  esac
  shift
done

if [[ ! "$limit" =~ ^[0-9]+$ ]]; then
  printf 'History line count must be a number.\n' >&2
  exit 1
fi

shiva_title "SHIVA HISTORY v$SHIVA_VERSION"

if [[ ! -r "$SHIVA_HISTORY_FILE" ]]; then
  printf 'No history recorded yet.\n'
  printf '\nHistory file: %s\n' "$SHIVA_HISTORY_FILE"
  exit 0
fi

awk -F '\t' -v module_filter="$module_filter" '
    module_filter == "" || $3 == module_filter { print }
  ' "$SHIVA_HISTORY_FILE" |
  tail -n "$limit" |
  awk -F '\t' '
    {
      split($1, parts, "T")
      day = parts[1]
      if (day != last_day) {
        if (last_day != "") print ""
        print day
        last_day = day
      }
      printf "  %-5s %-12s %s\n", $2, $3, $4
    }
  '
