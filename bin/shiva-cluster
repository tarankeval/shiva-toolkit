#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

json=false

usage() {
  cat <<'EOF'
Usage: shiva cluster [--json]

Show a compact infrastructure overview built from local Health Engine and nodes.
Remote node health checks are not performed yet.
EOF
}

while (($#)); do
  case "$1" in
    --json) json=true ;;
    -h|--help|help) usage; exit 0 ;;
    *) printf 'Unknown cluster option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

json_escape() {
  shiva_health_engine_json_escape "$1"
}

node_counts() {
  local entry host total=0 local_count=0 configured_count=0
  for entry in $SHIVA_NODES; do
    IFS=':' read -r _name _role host _extra <<<"$entry"
    [[ -n "${_name:-}" ]] || continue
    [[ -n "${host:-}" ]] || host="$_name"
    ((total+=1))
    if [[ "$host" == "$SHIVA_HOSTNAME" || "$host" == "localhost" || "$host" == "127.0.0.1" ]]; then
      ((local_count+=1))
    else
      ((configured_count+=1))
    fi
  done
  printf '%s %s %s' "$total" "$local_count" "$configured_count"
}

if [[ -r "$SHIVA_DASHBOARD_SNAPSHOT_FILE" ]]; then
  dashboard_json="$(<"$SHIVA_DASHBOARD_SNAPSHOT_FILE")"
else
  dashboard_json="$("$SCRIPT_DIR/shiva-dashboard" --json 2>/dev/null || true)"
fi
dashboard_value() {
  local key="$1"
  sed -n "s/.*\"$key\":\\([^,}]*\\).*/\\1/p" <<<"$dashboard_json" |
    sed 's/^"//;s/"$//'
}

read -r node_total node_local node_configured < <(node_counts)
overall="$(dashboard_value overall)"
health_percent="$(dashboard_value health_percent)"
failures="$(dashboard_value failures)"
warnings="$(dashboard_value warnings)"
watchdog="$(dashboard_value watchdog)"
telegram="$(dashboard_value telegram)"

: "${overall:=unknown}"
: "${health_percent:=0}"
: "${failures:=0}"
: "${warnings:=0}"
: "${watchdog:=unknown}"
: "${telegram:=disabled}"

if [[ "$json" == true ]]; then
  printf '{'
  shiva_json_metadata "health-engine" "$overall" "$health_percent"
  printf '"nodes":%s,' "$node_total"
  printf '"local_nodes":%s,' "$node_local"
  printf '"configured_nodes":%s,' "$node_configured"
  printf '"failures":%s,' "$failures"
  printf '"warnings":%s,' "$warnings"
  printf '"watchdog":"%s",' "$(json_escape "$watchdog")"
  printf '"telegram":"%s"' "$(json_escape "$telegram")"
  printf '}\n'
  exit 0
fi

shiva_title "SHIVA CLUSTER v$SHIVA_VERSION"
shiva_status ok "Nodes" "$node_total total, $node_local local, $node_configured configured"

case "$overall" in
  excellent) shiva_status ok "Health" "${health_percent}%" ;;
  good_with_warnings) shiva_status warn "Health" "${health_percent}%" ;;
  *) shiva_status fail "Health" "${health_percent}%" ;;
esac

case "$watchdog" in
  ok) shiva_status ok "Watchdog" "OK" ;;
  fail:*) shiva_status fail "Watchdog" "$watchdog" ;;
  *) shiva_status warn "Watchdog" "$watchdog" ;;
esac

if (( failures > 0 )); then
  shiva_status fail "Failures" "$failures"
else
  shiva_status ok "Failures" "$failures"
fi

if (( warnings > 0 )); then
  shiva_status warn "Warnings" "$warnings"
else
  shiva_status ok "Warnings" "$warnings"
fi

case "$telegram" in
  enabled) shiva_status ok "Telegram" "ENABLED" ;;
  *) shiva_status warn "Telegram" "DISABLED" ;;
esac
