#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

limit=100
json=false
notify=false
health_tmp="$(mktemp "${TMPDIR:-/tmp}/shiva-advisor.XXXXXX")" || exit 1
trap 'rm -f "$health_tmp"' EXIT

usage() {
  cat <<'EOF'
Usage: shiva advisor [--json] [--notify] [lines]

Show deterministic recommendations based on Shiva Health Engine and history.
Recommendation levels: INFO, RECOMMENDED, CRITICAL.
EOF
}

while (($#)); do
  case "$1" in
    --json) json=true ;;
    --notify) notify=true ;;
    -h|--help|help) usage; exit 0 ;;
    *) limit="$1" ;;
  esac
  shift
done

if [[ ! "$limit" =~ ^[0-9]+$ ]]; then
  printf 'Advisor history line count must be a number.\n' >&2
  exit 1
fi

recommendation_levels=()
recommendation_messages=()

recommend() {
  local level="$1" message="$2"
  recommendation_levels+=("$level")
  recommendation_messages+=("$message")
}

history_count() {
  local level="$1"
  [[ -r "$SHIVA_HISTORY_FILE" ]] || { printf '0'; return 0; }
  tail -n "$limit" "$SHIVA_HISTORY_FILE" |
    awk -F '\t' -v level="$level" '$2 == level {count += 1} END {print count + 0}'
}

watchdog_state() {
  [[ -r "$SHIVA_WATCHDOG_STATE_FILE" ]] || return 1
  cat "$SHIVA_WATCHDOG_STATE_FILE"
}

json_escape() {
  shiva_health_engine_json_escape "$1"
}

print_json() {
  local index
  printf '{'
  shiva_json_metadata "health-engine" "$overall" "$health_percent"
  printf '"history_window":%s,' "$limit"
  printf '"failures":%s,' "$fail_count"
  printf '"warnings":%s,' "$warn_count"
  printf '"watchdog_state":"%s",' "$(json_escape "$state")"
  printf '"checks":['
  awk -F '\t' '
    function esc(value) {
      gsub(/\\/,"\\\\",value)
      gsub(/"/,"\\\"",value)
      gsub(/\t/,"\\t",value)
      return value
    }
    {
      if (count > 0) printf ","
      printf "{\"level\":\"%s\",\"key\":\"%s\",\"label\":\"%s\",\"value\":\"%s\"}", esc($1), esc($2), esc($3), esc($4)
      count += 1
    }
  ' "$health_tmp"
  printf '],'
  printf '"recommendations":['
  for index in "${!recommendation_messages[@]}"; do
    (( index > 0 )) && printf ','
    printf '{"level":"%s","message":"%s"}' \
      "$(json_escape "${recommendation_levels[$index]}")" \
      "$(json_escape "${recommendation_messages[$index]}")"
  done
  printf ']}\n'
}

print_text() {
  local index
  shiva_title "SHIVA ADVISOR v$SHIVA_VERSION"
  printf 'Source: Health Engine\n'
  printf 'History window: last %s event(s)\n' "$limit"
  printf 'Failures: %s\n' "$fail_count"
  printf 'Warnings: %s\n' "$warn_count"
  [[ -n "$state" ]] && printf 'Watchdog state: %s\n' "$state"
  printf '\nRecommendations\n'
  if (( ${#recommendation_messages[@]} == 0 )); then
    printf 'No immediate recommendations.\n'
    return 0
  fi
  for index in "${!recommendation_messages[@]}"; do
    printf '%-11s %s\n' "${recommendation_levels[$index]}" "${recommendation_messages[$index]}"
  done
}

notify_recommendations() {
  local index message
  (( ${#recommendation_messages[@]} > 0 )) || return 0
  message="Shiva Advisor recommendations:"
  for index in "${!recommendation_messages[@]}"; do
    message+=$'\n'"${recommendation_levels[$index]}: ${recommendation_messages[$index]}"
  done
  "$SCRIPT_DIR/shiva-notify" --category advisor "$message"
}

shiva_health_engine_collect >"$health_tmp"
passed="$(awk -F '\t' '$1 == "ok" {count += 1} END {print count + 0}' "$health_tmp")"
fail_count="$(awk -F '\t' '$1 == "fail" {count += 1} END {print count + 0}' "$health_tmp")"
warn_count="$(awk -F '\t' '$1 == "warn" {count += 1} END {print count + 0}' "$health_tmp")"
total=$((passed + warn_count + fail_count))
if (( total > 0 )); then
  health_percent=$(((passed * 100 + warn_count * 50) / total))
else
  health_percent=0
fi
if (( fail_count > 0 )); then
  overall="attention_required"
elif (( warn_count > 0 )); then
  overall="good_with_warnings"
else
  overall="excellent"
fi
history_fail_count="$(history_count fail)"
history_warn_count="$(history_count warn)"
state="$(watchdog_state || true)"

while IFS=$'\t' read -r level key label value; do
  case "$level" in
    fail) recommend "CRITICAL" "$label is failing: $value" ;;
    warn) recommend "RECOMMENDED" "$label needs attention: $value" ;;
  esac
done <"$health_tmp"

if (( history_fail_count > 0 )); then
  recommend "RECOMMENDED" "Review recent failures with: shiva history --level fail"
fi

if (( history_warn_count > 0 )); then
  recommend "INFO" "Review warnings with: shiva history --level warn"
fi

case "$state" in
  fail:*)
    recommend "CRITICAL" "Inspect watchdog state with: shiva watchdog --status"
    recommend "RECOMMENDED" "Verify affected repair targets before applying changes"
    ;;
  "")
    recommend "INFO" "Run one watchdog cycle with: shiva watchdog --once"
    ;;
esac

if ! shiva_enabled "$SHIVA_TELEGRAM_ENABLED"; then
  recommend "INFO" "Configure Telegram notifications before relying on unattended watchdog alerts"
elif [[ -z "$SHIVA_TELEGRAM_BOT_TOKEN" || -z "$SHIVA_TELEGRAM_CHAT_ID" ]]; then
  recommend "RECOMMENDED" "Complete Telegram token and chat ID configuration"
fi

if ! shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR"; then
  recommend "INFO" "Keep auto-repair disabled until repair targets are verified on this host"
fi

if [[ "$json" == true ]]; then
  print_json
else
  print_text
fi

if [[ "$notify" == true ]]; then
  notify_recommendations
fi
