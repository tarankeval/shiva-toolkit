#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/shiva/bootstrap.sh" 2>/dev/null || source /usr/local/lib/shiva/bootstrap.sh
shiva_load_common

limit=100
json=false
notify=false

usage() {
  cat <<'EOF'
Usage: shiva advisor [--json] [--notify] [lines]

Show deterministic recommendations based on Shiva configuration and history.
EOF
}

while (($#)); do
  case "$1" in
    --json) json=true ;;
    --notify) notify=true ;;
    -h|--help|help) usage; exit 0 ;;
    *) limit="$1" ;;
  esac
  shift
done

if [[ ! "$limit" =~ ^[0-9]+$ ]]; then
  printf 'Advisor history line count must be a number.\n' >&2
  exit 1
fi

recommendations=()

recommend() {
  local message="$1"
  recommendations+=("$message")
}

history_count() {
  local level="$1"
  [[ -r "$SHIVA_HISTORY_FILE" ]] || { printf '0'; return 0; }
  tail -n "$limit" "$SHIVA_HISTORY_FILE" |
    awk -F '\t' -v level="$level" '$2 == level {count += 1} END {print count + 0}'
}

watchdog_state() {
  [[ -r "$SHIVA_WATCHDOG_STATE_FILE" ]] || return 1
  cat "$SHIVA_WATCHDOG_STATE_FILE"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

print_json() {
  local index recommendation
  printf '{'
  printf '"history_window":%s,' "$limit"
  printf '"failures":%s,' "$fail_count"
  printf '"warnings":%s,' "$warn_count"
  printf '"watchdog_state":"%s",' "$(json_escape "$state")"
  printf '"recommendations":['
  for index in "${!recommendations[@]}"; do
    recommendation="${recommendations[$index]}"
    (( index > 0 )) && printf ','
    printf '"%s"' "$(json_escape "$recommendation")"
  done
  printf ']}'
  printf '\n'
}

print_text() {
  local recommendation
  shiva_title "SHIVA ADVISOR v$SHIVA_VERSION"
  printf 'History window: last %s event(s)\n' "$limit"
  printf 'Failures: %s\n' "$fail_count"
  printf 'Warnings: %s\n' "$warn_count"
  [[ -n "$state" ]] && printf 'Watchdog state: %s\n' "$state"
  printf '\nRecommendations\n'
  if (( ${#recommendations[@]} == 0 )); then
    printf 'No immediate recommendations.\n'
    return 0
  fi
  for recommendation in "${recommendations[@]}"; do
    printf '%s\n' "- $recommendation"
  done
}

notify_recommendations() {
  local recommendation message
  (( ${#recommendations[@]} > 0 )) || return 0
  message="Shiva Advisor recommendations:"
  for recommendation in "${recommendations[@]}"; do
    message+=$'\n- '"$recommendation"
  done
  "$SCRIPT_DIR/shiva-notify" --category advisor "$message"
}

fail_count="$(history_count fail)"
warn_count="$(history_count warn)"
state="$(watchdog_state || true)"

if (( fail_count > 0 )); then
  recommend "Review recent failures with: shiva history --level fail"
fi

if (( warn_count > 0 )); then
  recommend "Review warnings with: shiva history --level warn"
fi

case "$state" in
  fail:*)
    recommend "Inspect watchdog state with: shiva watchdog --status"
    recommend "Verify affected repair targets before applying changes"
    ;;
  "")
    recommend "Run one watchdog cycle with: shiva watchdog --once"
    ;;
esac

if ! shiva_enabled "$SHIVA_TELEGRAM_ENABLED"; then
  recommend "Configure Telegram notifications before relying on unattended watchdog alerts"
elif [[ -z "$SHIVA_TELEGRAM_BOT_TOKEN" || -z "$SHIVA_TELEGRAM_CHAT_ID" ]]; then
  recommend "Complete Telegram token and chat ID configuration"
fi

if ! shiva_enabled "$SHIVA_WATCHDOG_AUTO_REPAIR"; then
  recommend "Keep auto-repair disabled until repair targets are verified on this host"
fi

if [[ "$json" == true ]]; then
  print_json
else
  print_text
fi

if [[ "$notify" == true ]]; then
  notify_recommendations
fi
