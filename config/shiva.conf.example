# Shiva Toolkit v1.1.0-dev Automation Preview global configuration.
#
# Host-specific checks are selected by:
#   /etc/shiva/profiles/<hostname>.conf
# and fall back to a built-in profile when available.
# Values in this file are optional final overrides.
#
# CHECK_TEMPERATURE=true
# CHECK_SMART=true
# CHECK_INTERFACES=true
# CHECK_DOCKER=true
# CHECK_OPENVPN=true
# CHECK_OCSERV=false
# CHECK_AMNEZIA=false
#
# Optional space-separated interfaces that must be UP. When empty, Shiva
# checks that at least one non-loopback interface is UP.
# REQUIRED_INTERFACES="eth0"
#
# Singular alias, supported for one required interface:
# REQUIRED_INTERFACE="tun0"

# Optional explicit physical disk for SMART. When empty, Shiva detects the
# physical disk underneath the root filesystem.
# SMART_DISK="/dev/sda"

# Local VPN client interfaces and optional Amnezia systemd service.
OPENVPN_INTERFACE="tun0"
AMNEZIA_INTERFACE="awg0"
AMNEZIA_SERVICE="awg-quick@awg0"

# Host used to verify DNS resolution.
SHIVA_DNS_TEST_HOST="example.com"

# TCP connection timeout in seconds.
SHIVA_CONNECT_TIMEOUT=3

# Automation and repair.
SHIVA_STATE_DIR="/var/lib/shiva"
SHIVA_HISTORY_FILE="/var/lib/shiva/history.log"
SHIVA_WATCHDOG_STATE_FILE="/var/lib/shiva/watchdog.state"
SHIVA_REPAIR_INTERFACE=""
SHIVA_OPENVPN_SERVICE=""
SHIVA_WATCHDOG_INTERVAL=60
SHIVA_WATCHDOG_AUTO_REPAIR=false
SHIVA_WATCHDOG_REPAIR_TARGETS="network dns openvpn"
SHIVA_NOTIFY_ON_WATCHDOG=true
SHIVA_NOTIFY_COOLDOWN_SECONDS=900
SHIVA_NOTIFY_STATE_DIR="/var/lib/shiva/notify"

# Telegram notifications. Keep token and chat ID outside git-tracked files.
SHIVA_TELEGRAM_ENABLED=false
SHIVA_TELEGRAM_BOT_TOKEN=""
SHIVA_TELEGRAM_CHAT_ID=""

# Backup freshness check.
SHIVA_BACKUP_DIR="/var/backups"
SHIVA_BACKUP_MAX_AGE_HOURS=48

# Number of warning/error journal lines shown by shiva-logs.
SHIVA_LOG_LINES=50
